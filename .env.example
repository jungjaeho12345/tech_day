# 미디어 검색 프록시 서버용 환경 변수 (서버 측 전용 — 클라이언트에 노출 금지)
# 모든 키는 Google Cloud Console > API 및 서비스에서 발급한다.

# 영상 탭(YouTube): Google Cloud Console > YouTube Data API v3 활성화 후 API 키 발급
YOUTUBE_API_KEY=

# 이미지 탭(Google 이미지 검색): Google Cloud Console > Custom Search JSON API 활성화 후 API 키 발급
GOOGLE_API_KEY=

# Programmable Search Engine(CX) ID: programmablesearchengine.google.com 에서 검색엔진 생성 시
# "이미지 검색" 옵션을 켠 뒤 발급되는 검색엔진 ID
GOOGLE_SEARCH_CX=
