{
  "name": "article-production-system",
  "version": "0.1.0",
  "description": "기사 작성기 - DB foundation layer (SPEC-DB-FOUNDATION-001)",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=22.5.0"
  },
  "scripts": {
    "dev": "vite web",
    "build": "vite build web",
    "preview": "vite preview web",
    "test": "node --experimental-sqlite --test --experimental-test-coverage test/*.test.js",
    "test:backend": "node --experimental-sqlite --test --experimental-test-coverage test/*.test.js",
    "test:web": "vitest run --root web",
    "test:web:coverage": "vitest run --root web --coverage",
    "coverage": "node --test --experimental-sqlite --experimental-test-coverage test/*.test.js",
    "server": "node --env-file-if-exists=.env server/index.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "express": "^4.22.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^5.0.4",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "jsdom": "^26.1.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "vite": "^7.1.9",
    "vitest": "^3.2.4"
  }
}
