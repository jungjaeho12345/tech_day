{
  "name": "article-production-system",
  "version": "0.1.0",
  "description": "기사 제작 시스템 - DB foundation layer (SPEC-DB-FOUNDATION-001)",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=22.5.0"
  },
  "scripts": {
    "test": "node --experimental-sqlite --test --experimental-test-coverage test/*.test.js",
